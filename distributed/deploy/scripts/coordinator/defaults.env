# Coordinator install defaults — sourced by install.sh.
# Shell-style assignments only. Keep paths absolute.

BINARY_NAME="zisk-coordinator"
BINARY_DST="/usr/local/bin/${BINARY_NAME}"
CONFIG_DIR="/etc/zisk"
CONFIG_DST="${CONFIG_DIR}/coordinator.toml"
SERVICE_USER="${BINARY_NAME}"
SERVICE_GROUP="${BINARY_NAME}"

# Per-service mutable state — /var/lib/ on Linux, /usr/local/var/ on macOS
# (mac /var/lib/ doesn't exist by default and trips SIP on rm -rf).
case "$OS_NAME" in
    Linux)  WORK_DIR="/var/lib/${BINARY_NAME}" ;;
    Darwin) WORK_DIR="/usr/local/var/${BINARY_NAME}" ;;
    *)      WORK_DIR="/var/lib/${BINARY_NAME}" ;;
esac

# Shared bundle dir (populated by ziskup --system). Linux: /opt/zisk;
# Darwin: /Library/Application Support/ZisK.
BUNDLE_DIR="$(bundle_dir_for_os)"

# Client-facing gRPC API port. Worker-facing (cluster) and metrics ports are
# left to the TOML config unless overridden via --cluster-port / --metrics-port.
DEFAULT_API_PORT="7000"

# Per-service log directory (used on both Linux and macOS)
LOG_DIR="/var/log/${BINARY_NAME}"

# Linux-specific
UNIT_FILE="/etc/systemd/system/${BINARY_NAME}.service"

# macOS-specific
LAUNCHD_LABEL="com.zisk.coordinator"
LAUNCHD_PLIST="/Library/LaunchDaemons/${LAUNCHD_LABEL}.plist"
NEWSYSLOG_CONF="/etc/newsyslog.d/${BINARY_NAME}.conf"
LOG_MAX_SIZE_MB="100"
LOG_ROTATIONS="5"
