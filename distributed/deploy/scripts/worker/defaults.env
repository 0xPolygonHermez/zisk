# Worker install defaults — sourced by install.sh and install-macos.sh.
# Shell-style assignments only. Keep paths absolute.

BINARY_NAME="zisk-worker"
BINARY_DST="/usr/local/bin/${BINARY_NAME}"
CONFIG_DIR="/etc/zisk"
CONFIG_DST="${CONFIG_DIR}/worker.toml"
WORK_DIR="/var/lib/zisk-worker"
SERVICE_USER="${BINARY_NAME}"
SERVICE_GROUP="${BINARY_NAME}"

# Shared bundle dir (populated by ziskup --system at install time).
# Linux: /opt/zisk; Darwin: /Library/Application Support/ZisK.
BUNDLE_DIR="$(bundle_dir_for_os)"

# Default proving key location (override with --proving-key). Lives inside the
# shared bundle so multiple services on the same host share one copy.
PROVING_KEY_DEFAULT="${BUNDLE_DIR}/provingKey"

# Per-service log directory (used on both Linux and macOS)
LOG_DIR="/var/log/${BINARY_NAME}"

# Linux-specific
UNIT_FILE="/etc/systemd/system/${BINARY_NAME}.service"

# macOS-specific
LAUNCHD_LABEL="com.zisk.worker"
LAUNCHD_PLIST="/Library/LaunchDaemons/${LAUNCHD_LABEL}.plist"
NEWSYSLOG_CONF="/etc/newsyslog.d/${BINARY_NAME}.conf"
LOG_MAX_SIZE_MB="100"
LOG_ROTATIONS="5"
