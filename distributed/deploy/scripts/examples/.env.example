# .env.example — template for ZisK install-time configuration.
#
# Usage:
#   cp distributed/deploy/scripts/examples/.env.example ./.env   # auto-loaded
#     — or —
#   sudo ./distributed/deploy/scripts/coordinator/install.sh --env path/to/zisk.env
#   sudo ./distributed/deploy/scripts/worker/install.sh      --env path/to/zisk.env
#
# Both install scripts read this file. Each consumes only the prefix it cares
# about (ZISK_COORDINATOR_* / ZISK_WORKER_* / RUST_LOG). Unset vars fall through
# to defaults.env, then to TOML defaults, then to binary auto-defaults.
#
# Replace the placeholder URLs/paths below before running. Treat the deployed
# copy as part of operational config (track in your IaC/Ansible alongside other
# environment data). Nothing here is a secret.
#
# IMPORTANT: these are install-time values. The install script bakes them into
# ExecStart as CLI flags and writes the unit file. Editing this file after
# installing has NO effect on a running daemon — re-run install.sh to apply.

# ── coordinator ───────────────────────────────────────────────────────────────
# Pre-built binary path (skip cargo build). Config file installed beforehand.

ZISK_COORDINATOR_BINARY=/usr/local/bin/zisk-coordinator
ZISK_COORDINATOR_CONFIG=/etc/zisk/coordinator.toml
ZISK_COORDINATOR_API_PORT=7000
ZISK_COORDINATOR_CLUSTER_PORT=7001
ZISK_COORDINATOR_METRICS_PORT=9090

# ── worker ────────────────────────────────────────────────────────────────────
# GPU + MPI. mpi_params.sh auto-tunes -np / ppr / threads from socket + GPU
# count; uncomment the manual overrides only to pin specific values
# (e.g. for benchmarking or non-uniform host layouts).
#
# Mode (--emulator vs --asm) is mutually exclusive at the binary. With both
# unset here, the install script appends neither flag and worker.toml decides.
# Set ZISK_WORKER_EMULATOR=true OR ZISK_WORKER_ASM=<path> to override TOML.

ZISK_WORKER_BINARY=/usr/local/bin/zisk-worker
ZISK_WORKER_CONFIG=/etc/zisk/worker.toml
ZISK_WORKER_PROVING_KEY=/var/lib/zisk-worker/provingKey
ZISK_WORKER_COORDINATOR_URL=https://coordinator.internal.example:7001

# ZISK_WORKER_ID=worker-01            # leave unset → auto-UUID per launch
ZISK_WORKER_COMPUTE_CAPACITY=10

# ZISK_WORKER_EMULATOR=true           # mutex with ZISK_WORKER_ASM
# ZISK_WORKER_ASM=/usr/local/share/zisk/program.asm
ZISK_WORKER_GPU=true

ZISK_WORKER_MPI=true
# ZISK_WORKER_MPI_PROCESSES=4         # leave unset → auto-detect
# ZISK_WORKER_MPI_NUMA_PPR=1
# ZISK_WORKER_MPI_THREADS=16

# ── shared ────────────────────────────────────────────────────────────────────
# `info` is a sensible default; use `debug`/`trace` for development, `warn` if
# logs are too noisy in production.
RUST_LOG=info
