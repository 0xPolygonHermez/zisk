# Example Postgres credentials file consumed by compose.yaml via env_file.
# Copy to postgres.env and set a real value before booting:
#   cp postgres.env.example postgres.env
#   $EDITOR postgres.env
# postgres.env is gitignored; never commit a real value.
#
# POSTGRES_PASSWORD is consumed by the Postgres service itself.
# ZISK_POSTGRES_PASSWORD is consumed by the Grafana datasource
# provisioning template; keep both in sync.
POSTGRES_PASSWORD=change-me
ZISK_POSTGRES_PASSWORD=change-me
