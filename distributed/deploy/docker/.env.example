# Copy to .env (same dir as compose.local.yaml / compose.yaml). Docker
# compose auto-loads .env, so `docker compose -f compose.local.yaml up -d`
# picks these values up without exporting anything.

# --- Coord scrape targets (LOCAL stack) -------------------------------------
# Comma-separated list `id=host:port`. The id becomes the coordinator_id
# label and must match --coordinator-id the coord was launched with.
# Multiple coords are supported; Prometheus scrapes each, the $coordinator
# dropdown filters the dashboard.
ZISK_COORDS=coord-mac-2=host.docker.internal:29090

# Legacy single-coord vars, used only when ZISK_COORDS is unset.
# ZISK_COORD_ID=coord-mac-2
# ZISK_COORD_HOST=host.docker.internal:29090

# Grafana Infinity JSON datasource base URL. Currently single-coord only.
ZISK_COORDINATOR_API_URL=http://host.docker.internal:29090

# Bearer token file shared with Prometheus. Generate once:
#   openssl rand -hex 32 > .zisk-scrape-token && chmod 600 .zisk-scrape-token
ZISK_SCRAPE_TOKEN_FILE=./.zisk-scrape-token

# Required by Postgres and Grafana datasource provisioning in local compose.
# Set this in your copied .env file; do not commit the filled value.
# ZISK_POSTGRES_PASSWORD=

# --- Production compose.yaml only -------------------------------------------
# These point at in-network docker hostnames and only apply when running the
# full production stack (compose.yaml).
# ZISK_PROMETHEUS_URL=http://prometheus:9090
