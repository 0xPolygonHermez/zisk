#!/usr/bin/env bash

# Reference: https://github.com/foundry-rs/foundry/blob/master/foundryup/foundryup

set -eo pipefail

BASE_DIR=${XDG_CONFIG_HOME:-${HOME}}
DEFAULT_USER_ZISK_DIR=${ZISK_DIR:-"${BASE_DIR}/.zisk"}
BINS=(cargo-zisk ziskemu)
BUCKET_URL="https://storage.googleapis.com/zisk-setup"

# Filled in by main() after arg parsing.
ZISK_DIR=""
ZISK_BIN_DIR=""
CARGO_ZISK=""
SYSTEM_MODE=false
PREFIX=""
OWNER=""
ASSUME_YES=false
FORCE=false
WITH_SNARK=false
UNINSTALL=false

# Receipt of what ziskup installed, written into ${ZISK_DIR}. Single file,
# key=value format, bash-parseable (no jq/yq dependency). Read by --uninstall
# to undo only what was installed. Schema:
#   version       — bare version string ("0.17.0"). --system short-circuits on
#                   match unless --force.
#   manifest      — space-separated list of subdirs ziskup created (bin, zisk,
#                   provingKey, provingKeySnark, toolchains, ...). --uninstall
#                   only removes what's listed, so operator-supplied files in
#                   the prefix survive.
#   created_user  — set only if ziskup CREATED the system user (vs. operator
#                   pre-created it). Empty/missing means do-not-touch.
#                   --uninstall keys off this — ziskup undoes only what it did.
#   created_group — same as created_user but for the group.
ZISK_RECEIPT_FILE=".zisk-receipt"

# Bundle subdirs ziskup populates. Used by `--uninstall` as the fallback when
# the state file is missing (older installs). The install path adds the
# matching entries to the manifest as artifacts land. When you add a new
# subdir, append it here AND emit a manifest_add call at the install site.
ZISK_KNOWN_SUBDIRS=(bin zisk provingKey provingKeySnark verifyKey cache toolchains)

main() {
  need_cmd curl

  # Check if this is a setup_snark command
  if [[ "${1:-}" == "setup_snark" ]]; then
    setup_snark_command
    exit 0
  fi

  while [[ -n $1 ]]; do
    case $1 in
    --)
      shift
      break
      ;;
    -v | --version)
      shift
      ZISK_VERSION=$1
      ;;
    --arch)
      shift
      ZISKUP_ARCH=$1
      ;;
    --platform)
      shift
      ZISKUP_PLATFORM=$1
      ;;
    --provingkey)
      SETUP_KEY="proving"
      ;;
    --verifykey)
      SETUP_KEY="verify"
      ;;
    --nokey)
      SETUP_KEY="none"
      ;;
    --gpu)
      if [[ "${USE_GPU}" == "false" ]]; then
        err "--gpu and --cpu are mutually exclusive"
        exit 1
      fi
      USE_GPU=true
      ;;
    --cpu)
      if [[ "${USE_GPU}" == "true" ]]; then
        err "--gpu and --cpu are mutually exclusive"
        exit 1
      fi
      USE_GPU=false
      ;;
    --system)
      SYSTEM_MODE=true
      ;;
    --prefix)
      shift
      PREFIX=$1
      ;;
    --owner)
      shift
      OWNER=$1
      ;;
    -y | --yes)
      ASSUME_YES=true
      ;;
    --force)
      FORCE=true
      ;;
    --with-snark)
      WITH_SNARK=true
      ;;
    --uninstall)
      UNINSTALL=true
      ;;
    -h | --help)
      usage
      exit 0
      ;;
    *)
      err "unknown option: $1"
      echo
      usage
      exit 1
      ;;
    esac
    shift
  done

  # --uninstall is its own flow — runs and exits before the install path below.
  if $UNINSTALL; then
    uninstall_command
    exit 0
  fi

  # Resolve install root and identity now that flags are parsed.
  if $SYSTEM_MODE; then
    if [[ "$(id -u)" -ne 0 ]]; then
      err "ziskup --system requires root"
      exit 1
    fi
    if [[ -z "$PREFIX" ]]; then
      case "$(uname -s)" in
        Linux)  PREFIX="/opt/zisk" ;;
        Darwin) PREFIX="/Library/Application Support/ZisK" ;;
        *) err "unsupported platform for --system: $(uname -s)"; exit 1 ;;
      esac
    fi
    if [[ -z "$OWNER" ]]; then
      OWNER="zisk:zisk"
    fi
  fi

  # --with-snark only makes sense for --system installs (services co-locate the
  # SNARK key inside the shared bundle). User-mode installs use `ziskup setup_snark`.
  if $WITH_SNARK && ! $SYSTEM_MODE; then
    err "--with-snark requires --system (use 'ziskup setup_snark' for user-mode SNARK key)"
    exit 1
  fi
  if [[ -n "$PREFIX" ]]; then
    ZISK_DIR="$PREFIX"
  else
    ZISK_DIR="$DEFAULT_USER_ZISK_DIR"
  fi
  ZISK_BIN_DIR="${ZISK_DIR}/bin"
  CARGO_ZISK="${ZISK_BIN_DIR}/cargo-zisk"

  mkdir -p "${ZISK_BIN_DIR}"

  if $SYSTEM_MODE; then
    ensure_owner_user_group "$OWNER" "$ZISK_DIR"
  fi

  uname_s=$(uname -s)
  PLATFORM=$(tolower "${ZISKUP_PLATFORM:-${uname_s}}")

  # DISCLAIMER:
  # macOS (Darwin) is explicitly unsupported and will trigger an error.
  case "${PLATFORM}" in
    linux) ;;
    darwin | mac*) ;;
    *)
      err "unsupported platform ${PLATFORM}"
      exit 1
      ;;
  esac

  # Detect CUDA toolkit availability.
  HAS_CUDA=false
  if [ "${PLATFORM}" = "linux" ] && {
    [ -d "/usr/local/cuda" ] || [ -n "${CUDA_HOME+x}" ] || (check_cmd nvcc && nvcc --version >/dev/null 2>&1)
  }; then
    HAS_CUDA=true
  fi

  # Print the banner after successfully parsing args
  banner

  # Check if the user provided a version
  if [[ -z "${ZISK_VERSION}" ]]; then
    ZISK_VERSION="latest"
  else
    ZISK_VERSION="v${ZISK_VERSION}"
  fi

  # In --system mode, short-circuit if the bundle is already installed at the
  # requested version. Avoids re-downloading the tarball when both worker and
  # coordinator install on the same host. Pass --force to refresh anyway.
  # State file stores bare version (e.g. "0.17.0"); requested version may be
  # "latest" or "vX.Y.Z" — strip the leading 'v' before comparing.
  if $SYSTEM_MODE && ! $FORCE; then
    installed=$(receipt_get version)
    requested="${ZISK_VERSION#v}"
    if [[ -n "$installed" ]] && \
       { [[ "$requested" == "latest" ]] || [[ "$requested" == "$installed" ]]; }; then
      step "Bundle already installed at ${installed} (in ${ZISK_DIR})."
      say "Use --force to refresh, or --version <X> to install a different version."
      return 0
    fi
  fi

  ZISKUP_REPO="0xPolygonHermez/zisk"
  EXT="tar.gz"

  step "Installing ZisK ${ZISK_VERSION} version..."

  uname_m=$(uname -m)
  ARCHITECTURE=$(tolower "${ZISKUP_ARCH:-${uname_m}}")
  if [ "${ARCHITECTURE}" = "x86_64" ]; then
    # Redirect stderr to /dev/null to avoid printing errors if non Rosetta.
    if [ "$(sysctl -n sysctl.proc_translated 2>/dev/null)" = "1" ]; then
      ARCHITECTURE="arm64" # Rosetta.
    else
      ARCHITECTURE="amd64" # Intel.
    fi
  elif [ "${ARCHITECTURE}" = "arm64" ] || [ "${ARCHITECTURE}" = "aarch64" ]; then
    ARCHITECTURE="arm64" # Arm.
  else
    ARCHITECTURE="amd64" # Amd.
  fi

  # If we are running in a GitHub action, we install the proving key by default
  if [[ -n "${GH_RUNNER}" ]]; then
    warn "Running from GitHub action, installing proving key"
    SETUP_KEY="proving"
    USE_GPU=false
  fi

  # Determine whether to use GPU or CPU binaries (linux only), if USE_GPU is not set
  if [[ -z "${USE_GPU}" ]]; then
    if [ "${PLATFORM}" = "linux" ]; then
      if [ "${HAS_CUDA}" = "true" ]; then
        USE_GPU=true
      elif $ASSUME_YES; then
        USE_GPU=false
      else
        warn "CUDA was not detected on this system"
        say "The version with only CPU support will be installed by default"
        say ""
        say "Do you want to:"
        say "  1) Install CPU version (default - just press enter)"
        say "  2) Install GPU version"
        read -p ">" cuda_choice < /dev/tty
        cuda_choice=${cuda_choice:-1}

        case "${cuda_choice}" in
          1) USE_GPU=false ;;
          2) USE_GPU=true ;;
          *)
            err "invalid option, aborting installation"
            exit 1
            ;;
        esac
      fi
    else
      # For macOS, we only install the CPU version as GPU support is not available yet
      USE_GPU=false
    fi
  fi

  # Ask user about key installation if SETUP_KEY is not set
  if [[ -z "${SETUP_KEY}" ]]; then
    if $ASSUME_YES; then
      SETUP_KEY="proving"
    else
      step "Setup installation options:"
      say "1) Install proving key (default - just press enter)"
      say "2) Install proving key (no constant tree files)"
      say "3) Install verify key"
      say "4) None"

      # Read user input with default option set to 1
      read -p ">" user_choice < /dev/tty
      user_choice=${user_choice:-1}

      case "${user_choice}" in
          1)
            SETUP_KEY="proving"
            ;;
          2)
            SETUP_KEY="proving-no-consttree"
            ;;
          3)
            SETUP_KEY="verify"
            ;;
          4)
            SETUP_KEY="none"
            ;;
          *)
            err "invalid option, aborting installation"
            exit 1
            ;;
      esac
    fi
  fi

  # Compute the URL of the release tarball in the zisk repository
  if [ "${ZISK_VERSION}" = "latest" ]; then
    RELEASE_URL="https://github.com/${ZISKUP_REPO}/releases/latest/download/"
  else
    RELEASE_URL="https://github.com/${ZISKUP_REPO}/releases/download/${ZISK_VERSION}/"
  fi

  BIN_ARCHIVE_URL="${RELEASE_URL}cargo_zisk_${PLATFORM}_${ARCHITECTURE}.${EXT}"

  # Download and extract the binaries archive
  if [ "${PLATFORM}" = "linux" ] || [ "${PLATFORM}" = "darwin" ]; then
    tmp="$(mktemp -d)/cargo_zisk.tar.gz"

    step "Downloading ZisK ${ZISK_VERSION} version..."
    ensure download "${BIN_ARCHIVE_URL}" "${tmp}"

    step "Installing ZisK ${ZISK_VERSION} version..."
    if [ "${PLATFORM}" = "linux" ]; then
      ensure tar --overwrite -xzf "${tmp}" -C "${ZISK_DIR}"
    else
      ensure tar -xzf "${tmp}" -C "${ZISK_DIR}"
    fi

    rm -f "${tmp}"

    if [ "${PLATFORM}" = "linux" ]; then
      # Set up binaries based on GPU/CPU selection (linux only)
      if [ "${USE_GPU}" = "true" ]; then
        step "Configuring GPU binaries..."
        rm -f "${ZISK_BIN_DIR}/cargo-zisk-cpu"
        rm -f "${ZISK_BIN_DIR}/zisk-worker-cpu"
        mv "${ZISK_BIN_DIR}/cargo-zisk-gpu" "${ZISK_BIN_DIR}/cargo-zisk"
        mv "${ZISK_BIN_DIR}/zisk-worker-gpu" "${ZISK_BIN_DIR}/zisk-worker"
      else
        step "Configuring CPU binaries..."
        rm -f "${ZISK_BIN_DIR}/cargo-zisk-gpu"
        rm -f "${ZISK_BIN_DIR}/zisk-worker-gpu"
        mv "${ZISK_BIN_DIR}/cargo-zisk-cpu" "${ZISK_BIN_DIR}/cargo-zisk"
        mv "${ZISK_BIN_DIR}/zisk-worker-cpu" "${ZISK_BIN_DIR}/zisk-worker"
      fi
    fi
  fi

  # Print installed version message
  ZISK_VERSION=$(echo "$(ensure "${CARGO_ZISK}" --version)" | awk '{print $2}')
  say "Installed ZisK version ${ZISK_VERSION}"

  # Stamp the bundle so subsequent --system runs can short-circuit.
  receipt_set version "${ZISK_VERSION}"

  manifest_reset
  manifest_add bin
  [[ -d "${ZISK_DIR}/zisk" ]] && manifest_add zisk

  for bin in "${BINS[@]}"; do
    bin_path="$ZISK_BIN_DIR/$bin"

    # Check if the default path of the binary is not in ZISK_BIN_DIR
    which_path="$(command -v "${bin}" || true)"
    if [ -n "$which_path" ] && [ "${which_path}" != "${bin_path}" ]; then
      warn ""
      cat 1>&2 <<EOF
There are multiple binaries with the name '${bin}' present in your 'PATH'.
This may be the result of installing '${bin}' using another method,
like Cargo or other package managers.
You may need to run 'rm ${which_path}' or move '${ZISK_BIN_DIR}'
in your 'PATH' to allow the newly installed version to take precedence!

EOF
    fi
  done

  if ! $SYSTEM_MODE; then
    step "Installing ZisK Rust toolchain..."
    ensure "${CARGO_ZISK}" toolchain install
    manifest_add toolchains
  fi

  # Install the proving/verify key setup
  IFS='.' read -r major minor patch <<< "${ZISK_VERSION}"
  SETUP_VERSION="${major}.${minor}.0"
  case "${SETUP_KEY}" in
    proving)
      install_setup "proving" 1
      manifest_add provingKey
      ;;
    proving-no-consttree)
      install_setup "proving" 0
      manifest_add provingKey
      ;;
    verify)
      install_setup "verify" 0
      manifest_add verifyKey
      ;;
    none)
      # Do nothing
      ;;
    *)
      err "invalid key option, aborting installation"
      exit 1
      ;;
  esac

  # SNARK proving key (system mode only — gated by --with-snark validation above).
  # Skipped if already present unless --force was passed.
  if $WITH_SNARK; then
    if ! $FORCE && [[ -d "${ZISK_DIR}/provingKeySnark" ]]; then
      step "SNARK proving key already installed at ${ZISK_DIR}/provingKeySnark."
      say "Use --force to refresh."
    else
      install_setup_snark
    fi
    manifest_add provingKeySnark
  fi

  if $SYSTEM_MODE; then
    # Apply ownership and tighten permissions on the bundle.
    chown -R "$OWNER" "$ZISK_DIR"
    find "$ZISK_DIR" -type d -exec chmod 0750 {} \;
    if [[ -d "$ZISK_BIN_DIR" ]]; then
      find "$ZISK_BIN_DIR" -type f -exec chmod 0750 {} \;
    fi

    step "Done! ZisK version ${ZISK_VERSION} has been installed at ${ZISK_DIR}."
    say "Set ZISK_HOME=${ZISK_DIR} in your service unit (Environment=) so the worker resolves bundle paths."
    echo
    return
  fi

  # Determine the profile file and preferred shell based on the current shell
  case "${SHELL}" in
    */zsh)
      PROFILE=${ZDOTDIR:-${HOME}}/.zshenv
      PREF_SHELL="zsh"
      ;;
    */bash)
      PROFILE=${HOME}/.bashrc
      PREF_SHELL="bash"
      ;;
    */fish)
      PROFILE=${HOME}/.config/fish/config.fish
      PREF_SHELL="fish"
      ;;
    */ash)
      PROFILE=${HOME}/.profile
      PREF_SHELL="ash"
      ;;
    *)
      warn "could not detect shell, manually add ${ZISK_BIN_DIR} to your PATH"
      exit 1
      ;;
  esac

  # Only add ziskup if it isn't already in PATH.
  if [[ ":${PATH}:" != *":${ZISK_BIN_DIR}:"* ]]; then
      # Add the ziskup directory to the path and ensure the old PATH variables remain.
      echo "Adding ZisK to your PATH..."
      echo >>"${PROFILE}" && echo "export PATH=\"\$PATH:${ZISK_BIN_DIR}\"" >>"${PROFILE}"
  fi

  step "Done! ZisK version ${ZISK_VERSION} has been installed."
  say "Your preferred shell '${PREF_SHELL}' was detected and ZisK has been added to your PATH. To start using the ZisK CLI tools, run 'source ${PROFILE}' or open a new terminal session."
  echo
}

usage() {
  cat 1>&2 <<EOF
The installer for the ZisK.

Update or revert to a specific ZisK version with ease.

USAGE:
    ziskup <OPTIONS>

OPTIONS:
    -h, --help      Print help information
    -v, --version   Install a specific version
    --arch          Install a specific architecture (supports amd64 and arm64)
    --platform     Install a specific platform (supports linux and darwin)
    --provingkey   Install the proving key
    --verifykey    Install the verify key
    --gpu          Install the GPU version (linux only)
    --cpu          Install the CPU version (linux only)
    --nokey        No proving/verify key installation
    --system       System-wide install (root required). Defaults --prefix to
                   /opt/zisk on Linux or /Library/Application Support/ZisK on macOS,
                   defaults --owner to zisk:zisk (created if missing). Skips toolchain
                   install and PATH/profile mutation.
    --prefix DIR   Install to DIR instead of \$HOME/.zisk (or the system default
                   when used with --system).
    --owner U:G    chown the install tree to U:G after extraction. With --system,
                   missing user or group are created in the system uid/gid range.
    -y, --yes      Non-interactive: accept defaults for prompts.
    --force        With --system: re-install even if the version marker shows the
                   bundle is already at the requested version. Default is to
                   short-circuit (avoids re-download when worker + coordinator
                   install on the same host).
    --with-snark   Only works with --system. Download and install the SNARK proving key.
                   Skipped if already present unless --force is also given.
    --uninstall    Remove the ZisK bundle. Only the subdirs ziskup tracked at install
                   time are deleted (operator-supplied files in the prefix survive).
                   Combine with --system for the system bundle. With --system also
                   removes the zisk system user/group iff ziskup itself created them
                   (operator-managed users are never touched). Refuses to run while
                   a ZisK service is still installed unless --force is given.

COMMANDS:
    setup_snark     Install SNARK proving key (provingKeySnark)
EOF
}

say() {
  printf "%s\n" "$1"
}

step() {
  echo
  printf "\033[0;32m%s\033[0m\n" "$1"
}

warn() {
  printf "\033[0;33mWarning: %s\033[0m\n" "$1"
}

err() {
  printf "\033[0;31mError: %s\033[0m\n" "$1" >&2
}

tolower() {
  echo "$1" | awk '{print tolower($0)}'
}

need_cmd() {
  if ! check_cmd "$1"; then
    err "need '$1' (command not found)"
  fi
}

check_cmd() {
  command -v "$1" &>/dev/null
}

# Create the user:group from "$1" if missing, with $2 as the user's home dir.
# Behavior is platform-aware: useradd/groupadd on Linux, dscl on macOS.
# Records created_user / created_group in the state file ONLY when the
# user/group was actually created (not when it pre-existed). --uninstall
# keys off these fields, so operator-managed users are never removed by
# ziskup — it undoes only what it did.
ensure_owner_user_group() {
  local owner="$1"
  local home_dir="$2"
  local user_name="${owner%%:*}"
  local group_name="${owner##*:}"
  if [[ -z "$user_name" || -z "$group_name" || "$user_name" == "$owner" ]]; then
    err "--owner expected user:group, got: $owner"
    exit 1
  fi
  local created_user=false created_group=false
  case "$(uname -s)" in
    Linux)
      if ! getent group "$group_name" >/dev/null 2>&1; then
        ensure groupadd --system "$group_name"
        created_group=true
      fi
      if ! id "$user_name" >/dev/null 2>&1; then
        ensure useradd --system -g "$group_name" -d "$home_dir" -s /usr/sbin/nologin "$user_name"
        created_user=true
      fi
      ;;
    Darwin)
      # Find a free GID/UID below 500 (system range on macOS).
      if ! dscl . -read "/Groups/$group_name" >/dev/null 2>&1; then
        local gid=300
        while dscl . -read "/Groups/_g$gid" >/dev/null 2>&1 || \
              dscl . -list /Groups gid 2>/dev/null | awk '{print $2}' | grep -q "^${gid}$"; do
          gid=$((gid + 1))
        done
        ensure dscl . -create "/Groups/$group_name"
        ensure dscl . -create "/Groups/$group_name" PrimaryGroupID "$gid"
        created_group=true
      fi
      if ! dscl . -read "/Users/$user_name" >/dev/null 2>&1; then
        local uid=300
        while dscl . -list /Users UniqueID 2>/dev/null | awk '{print $2}' | grep -q "^${uid}$"; do
          uid=$((uid + 1))
        done
        local gid
        gid=$(dscl . -read "/Groups/$group_name" PrimaryGroupID | awk '{print $2}')
        ensure dscl . -create "/Users/$user_name"
        ensure dscl . -create "/Users/$user_name" UniqueID "$uid"
        ensure dscl . -create "/Users/$user_name" PrimaryGroupID "$gid"
        ensure dscl . -create "/Users/$user_name" UserShell /usr/bin/false
        ensure dscl . -create "/Users/$user_name" NFSHomeDirectory "$home_dir"
        created_user=true
      fi
      ;;
    *)
      err "ensure_owner_user_group: unsupported platform $(uname -s)"
      exit 1
      ;;
  esac
  # Record in state file ONLY when WE actually created them. Empty/missing
  # entries tell --uninstall to leave operator-managed users alone.
  if $created_user;  then receipt_set created_user  "$user_name";  fi
  if $created_group; then receipt_set created_group "$group_name"; fi
}

# Path to the state file.
receipt_path() { echo "${ZISK_DIR}/${ZISK_RECEIPT_FILE}"; }

# Read a single value by key from the state file. Empty if key/file missing.
receipt_get() {
  local key="$1"
  local file; file=$(receipt_path)
  [[ -f "$file" ]] || return 0
  awk -F= -v k="$key" '$1 == k { sub(/^[^=]+=/, ""); print; exit }' "$file"
}

# Set key=value in the state file. Replaces existing line if present, else
# appends. Portable (no `sed -i`, which differs between GNU and BSD).
receipt_set() {
  local key="$1" value="$2"
  local file; file=$(receipt_path)
  mkdir -p "$(dirname "$file")"
  if [[ ! -f "$file" ]]; then
    {
      echo "# ZisK install receipt. Read by 'ziskup --uninstall'. Do not edit."
      echo "${key}=${value}"
    } > "$file"
    return 0
  fi
  awk -v k="$key" -v v="$value" -F= '
    $1 == k { print k "=" v; found=1; next }
    { print }
    END { if (!found) print k "=" v }
  ' "$file" > "${file}.tmp" && mv "${file}.tmp" "$file"
}

# Append a value to a space-separated list field (idempotent).
receipt_append_list() {
  local key="$1" value="$2"
  local current item
  current=$(receipt_get "$key")
  for item in $current; do
    [[ "$item" == "$value" ]] && return 0
  done
  if [[ -n "$current" ]]; then
    receipt_set "$key" "$current $value"
  else
    receipt_set "$key" "$value"
  fi
}

# Reset only the manifest field (other state — version, created_user — must
# survive). Called at install start so a re-install with different flags
# (e.g. --nokey vs --provingkey) doesn't accumulate stale subdirs.
manifest_reset() { receipt_set manifest ""; }

# Append a subdir to the manifest list (idempotent).
manifest_add()   { receipt_append_list manifest "$1"; }

# Run a command that should never fail. If the command fails execution
# will immediately terminate with an error showing the failing command.
ensure() {
  if ! "$@"; then
    err "command failed: $*";
    exit 1
  fi
}

# Run a command that should never fail and suppress the output. If the command fails execution
# will immediately terminate with an error showing the failing command.
ensure_silent() {
  if ! "$@" >/dev/null 2>&1; then
    err "command failed: $*"
    exit 1
  fi
}

# Downloads $1 into $2
download() {
  say $1
  if check_cmd curl; then
    curl -H "Accept: application/octet-stream" -L -#o "$2" "$1"
  else
    wget --header="Accept: application/octet-stream" --show-progress -qO "$2" "$1"
  fi
}

# Install the proving or verify key
install_setup() {
    local KEY_TYPE=$1  # proving or verify
    local CONST_TREE=$2
    local KEY_FILE="zisk-${KEY_TYPE}key-${SETUP_VERSION}.tar.gz"

    step "Downloading ${KEY_TYPE} key version ${SETUP_VERSION}..."
    ensure download "${BUCKET_URL}/${KEY_FILE}" "${KEY_FILE}"
    ensure download "${BUCKET_URL}/${KEY_FILE}.md5" "${KEY_FILE}.md5"

    # Verify the md5 checksum
    ensure md5sum -c "${KEY_FILE}.md5"

    # Delete old provingKey, verifyKey and cache folders
    rm -rf "${ZISK_DIR}/provingKey"
    rm -rf "${ZISK_DIR}/verifyKey"
    rm -rf "${ZISK_DIR}/cache"

    # Extract the key
    step "Installing ${KEY_TYPE} key version ${SETUP_VERSION}..."
    if [ "${PLATFORM}" = "linux" ]; then
      ensure tar --overwrite -xf "${KEY_FILE}" -C "${ZISK_DIR}"
    else
      ensure tar -xf "${KEY_FILE}" -C "${ZISK_DIR}"
    fi

    rm -f "${KEY_FILE}"
    rm -f "${KEY_FILE}.md5"
    say "Installed ${KEY_TYPE} key version ${SETUP_VERSION}"

    # Generate constant tree files for proving key
    if [[ "${KEY_TYPE}" == "proving" && "${CONST_TREE}" -eq 1 ]]; then
      step "Generating constant tree files. This may take a while..."
      ensure_silent "${CARGO_ZISK}" check-setup -a
      say "Constant tree files generated successfully."
    fi
}

# Install the SNARK proving key
install_setup_snark() {
    local KEY_FILE="zisk-provingkey-plonk-${SETUP_VERSION}.tar.gz"

    step "Downloading SNARK proving key version ${SETUP_VERSION}. This may take a while..."
    ensure download "${BUCKET_URL}/${KEY_FILE}" "${KEY_FILE}"
    ensure download "${BUCKET_URL}/${KEY_FILE}.md5" "${KEY_FILE}.md5"

    # Verify the md5 checksum
    ensure md5sum -c "${KEY_FILE}.md5"

    # Delete old provingKey, verifyKey and cache folders
    rm -rf "${ZISK_DIR}/provingKeySnark"

    # Extract the key
    step "Installing SNARK proving key version ${SETUP_VERSION}..."
    if [ "${PLATFORM}" = "linux" ]; then
      ensure tar --overwrite -xf "${KEY_FILE}" -C "${ZISK_DIR}"
    else
      ensure tar -xf "${KEY_FILE}" -C "${ZISK_DIR}"
    fi

    rm -f "${KEY_FILE}"
    rm -f "${KEY_FILE}.md5"
    say "Installed SNARK proving key version ${SETUP_VERSION}"
}

# Uninstall handler — invoked from main() when --uninstall is passed. Removes
# the ZisK bundle. Manifest-aware: only subdirs ziskup tracked at install time
# are removed, so operator-supplied files in the prefix survive. Uninstall
# refuses to run while a service unit/plist that references the bundle is
# still installed (override with --force).
uninstall_command() {
  banner

  # Resolve prefix using the same flag logic as install — operators get
  # consistent behavior whether they're installing or removing.
  if $SYSTEM_MODE; then
    if [[ "$(id -u)" -ne 0 ]]; then
      err "ziskup --uninstall --system requires root"
      exit 1
    fi
    if [[ -z "$PREFIX" ]]; then
      case "$(uname -s)" in
        Linux)  PREFIX="/opt/zisk" ;;
        Darwin) PREFIX="/Library/Application Support/ZisK" ;;
        *) err "unsupported platform for --system: $(uname -s)"; exit 1 ;;
      esac
    fi
  fi
  if [[ -n "$PREFIX" ]]; then
    ZISK_DIR="$PREFIX"
  else
    ZISK_DIR="$DEFAULT_USER_ZISK_DIR"
  fi

  if [[ ! -d "$ZISK_DIR" ]]; then
    warn "Nothing to uninstall: $ZISK_DIR does not exist"
    return 0
  fi

  # Sanity check: refuse to nuke the bundle while a ZisK service that
  # depends on it is still installed. --force overrides for emergency
  # cleanup. Only meaningful in --system mode (services live in /etc/...).
  if $SYSTEM_MODE && ! $FORCE; then
    local active_services=()
    case "$(uname -s)" in
      Linux)
        for s in /etc/systemd/system/zisk-*.service; do
          [[ -e "$s" ]] && active_services+=("$(basename "$s" .service)")
        done
        ;;
      Darwin)
        for p in /Library/LaunchDaemons/com.zisk.*.plist; do
          [[ -e "$p" ]] && active_services+=("$(basename "$p" .plist)")
        done
        ;;
    esac
    if [[ ${#active_services[@]} -gt 0 ]]; then
      err "Refusing to uninstall: service(s) still installed: ${active_services[*]}"
      err "Run their --uninstall first, or pass --force to proceed anyway."
      exit 1
    fi
  fi

  step "Removing ZisK bundle at $ZISK_DIR..."

  # Read manifest from state file. Fall back to ZISK_KNOWN_SUBDIRS for
  # bundles installed by older ziskups that didn't yet write state.
  local subdirs=() manifest_value
  manifest_value=$(receipt_get manifest)
  if [[ -n "$manifest_value" ]]; then
    read -r -a subdirs <<< "$manifest_value"
  else
    subdirs=("${ZISK_KNOWN_SUBDIRS[@]}")
  fi

  for sub in "${subdirs[@]}"; do
    if [[ -d "$ZISK_DIR/$sub" ]]; then
      rm -rf "$ZISK_DIR/$sub"
      say "  Removed $sub/"
    fi
  done

  # User/group cleanup — only when state recorded that ziskup itself created
  # them. Operator-managed users (no marker) are silently left alone:
  # ziskup undoes only what ziskup did.
  if $SYSTEM_MODE; then
    local u g
    u=$(receipt_get created_user)
    g=$(receipt_get created_group)
    case "$(uname -s)" in
      Linux)
        if [[ -n "$u" ]] && id "$u" >/dev/null 2>&1; then
          userdel "$u" 2>/dev/null && say "  Removed user '$u'" \
                                   || warn "  Could not remove user '$u'"
        fi
        if [[ -n "$g" ]] && getent group "$g" >/dev/null 2>&1; then
          groupdel "$g" 2>/dev/null && say "  Removed group '$g'" \
                                    || warn "  Could not remove group '$g'"
        fi
        ;;
      Darwin)
        if [[ -n "$u" ]] && dscl . -read "/Users/$u" >/dev/null 2>&1; then
          dscl . -delete "/Users/$u" && say "  Removed user '$u'"
        fi
        if [[ -n "$g" ]] && dscl . -read "/Groups/$g" >/dev/null 2>&1; then
          dscl . -delete "/Groups/$g" && say "  Removed group '$g'"
        fi
        ;;
    esac
  fi

  rm -f "$(receipt_path)"

  # Try rmdir — succeeds only if dir is empty. If operator put extra files
  # inside the prefix, they survive and the dir is left intact.
  if rmdir "$ZISK_DIR" 2>/dev/null; then
    say "  Removed empty $ZISK_DIR"
  else
    warn "  $ZISK_DIR not empty — operator-supplied files preserved"
  fi

  step "Done. ZisK uninstalled from $ZISK_DIR."
  echo
}

# Setup SNARK command handler
setup_snark_command() {
  # Print banner
  banner

  # Resolve install root (setup_snark uses the user-mode default).
  ZISK_DIR="$DEFAULT_USER_ZISK_DIR"
  ZISK_BIN_DIR="${ZISK_DIR}/bin"
  CARGO_ZISK="${ZISK_BIN_DIR}/cargo-zisk"

  # Detect platform
  uname_s=$(uname -s)
  PLATFORM=$(tolower "${uname_s}")

  case "${PLATFORM}" in
    linux) ;;
    darwin | mac*) ;;
    *)
      err "unsupported platform ${PLATFORM}"
      exit 1
      ;;
  esac

  # Determine version from cargo-zisk
  if [[ ! -f "${CARGO_ZISK}" ]]; then
    err "cargo-zisk not found. Please install ZisK first with 'ziskup'"
    exit 1
  fi

  ZISK_VERSION=$("${CARGO_ZISK}" --version | awk '{print $2}')

  # Parse version to get setup version
  IFS='.' read -r major minor patch <<< "${ZISK_VERSION}"
  SETUP_VERSION="${major}.${minor}.0"

  step "Installing SNARK proving key for ZisK version ${ZISK_VERSION}..."

  # Install the SNARK proving key
  install_setup_snark

  step "Done! SNARK proving key installation completed."
  echo
}

# Banner Function for ZisK
banner() {
  cat <<'EOF'

########################################################################################
 ______     _  __
|__  (_)___| |/ /
  / /| / __| ' /
 / /_| \__ \ . \
/____|_|___/_|\_\

Ziskup - The ZisK Installer

########################################################################################
EOF
}

main "$@"
